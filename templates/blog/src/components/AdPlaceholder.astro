---
interface Props {
	size?: "banner" | "rectangle" | "leaderboard";
	label?: string;
}

const { size = "rectangle", label = "Advertisement" } = Astro.props;
---

<div class={`ad-container ad-${size}`}>
	<span class="ad-label">{label}</span>
	<div id="ezoic-pub-ad-placeholder-101"></div>
</div>

<style>
	.ad-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: var(--spacing-8) 0;
	}

	.ad-label {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-align: center;
		margin-bottom: var(--spacing-2);
	}

	/* Rectangle 300x250 */
	.ad-rectangle {
		width: 300px;
		height: 250px;
	}

	/* Banner 728x90 */
	.ad-banner {
		width: 728px;
		max-width: 100%;
		height: 90px;
	}

	/* Leaderboard 970x90 */
	.ad-leaderboard {
		width: 970px;
		max-width: 100%;
		height: 90px;
	}

	/* Placeholder look until Ezoic/Mediavine loads */
	.ad-container > div {
		width: 100%;
		height: 100%;
		background: var(--color-surface);
		border: 1px dashed var(--color-border);
		border-radius: var(--radius);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	@media (max-width: 768px) {
		.ad-banner,
		.ad-leaderboard {
			width: 100%;
			height: auto;
			aspect-ratio: 728 / 90;
		}
	}
</style>
